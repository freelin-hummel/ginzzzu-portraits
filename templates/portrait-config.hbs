<form class="ginzzzu-portrait-config">
  <!-- Отображаемое имя -->
  <div class="form-group display-name-section">
    <label>{{label}}</label>
    <input
      type="text"
      name="displayName"
      value="{{displayName}}"
      placeholder="{{placeholder}}"
    />
    <p class="notes">{{notes}}</p>
  </div>
  
  <hr class="section-divider" />

  <!-- Кастомное изображение портрета -->
  <div class="form-group portrait-custom-image-section">
    <label>{{portraitCustomImageLabel}}</label>
    <div class="form-fields">
      <input
        type="text"
        name="portraitCustomImage"
        value="{{portraitCustomImage}}"
        placeholder="{{portraitCustomImagePlaceholder}}"
      />
      <button
        type="button"
        class="file-picker portrait-custom-image-picker"
        data-type="image"
        title="{{portraitCustomImageButtonHint}}"
      >
        <i class="fas fa-file-import"></i>
      </button>
    </div>
    <p class="notes">{{portraitCustomImageHint}}</p>
  </div>

  <section class="portrait-frame-section">
    <h3>Portrait frame</h3>
    <div class="portrait-frame-grid">
      <div class="form-group">
        <label>Border</label>
        <select name="frameStyle">
          {{#each frameOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
      <div class="form-group">
        <label>Image fit</label>
        <select name="frameFit">
          {{#each frameFitOptions}}<option value="{{value}}" {{#if selected}}selected{{/if}}>{{label}}</option>{{/each}}
        </select>
      </div>
    </div>
    <div class="form-group">
      <label>Custom nine-slice frame</label>
      <div class="form-fields">
        <input type="text" name="frameImage" value="{{frameImage}}" placeholder="path/to/frame.png" />
        <button type="button" class="file-picker portrait-frame-image-picker" title="Choose frame image"><i class="fas fa-file-import"></i></button>
      </div>
    </div>
    <div class="form-group">
      <label>Image inset</label>
      <div class="form-fields">
        <input type="range" name="framePadding" value="{{framePadding}}" min="0" max="20" step="1" />
        <output data-for="framePadding">{{framePadding}}%</output>
      </div>
    </div>
    <div class="portrait-frame-grid">
      <div class="form-group">
        <label>Border width</label>
        <div class="form-fields">
          <input type="range" name="frameWidth" value="{{frameWidth}}" min="2" max="48" step="1" />
          <output data-for="frameWidth">{{frameWidth}}px</output>
        </div>
      </div>
      <div class="form-group">
        <label>Custom slice</label>
        <div class="form-fields">
          <input type="range" name="frameSlice" value="{{frameSlice}}" min="1" max="49" step="1" />
          <output data-for="frameSlice">{{frameSlice}}%</output>
        </div>
      </div>
    </div>
  </section>

  <!-- Глобальная высота портрета -->
  <div class="form-group portrait-height-multiplier-section">
    <label>{{portraitHeightMultiplierLabel}}</label>
    <div class="form-fields">
      <input
        type="range"
        name="portraitHeightMultiplier"
        value="{{portraitHeightMultiplier}}"
        min="0"
        max="2"
        step="0.01"
      />
      <input
        type="number"
        class="multiplier-value-display"
        value="{{portraitHeightMultiplier}}"
        min="0"
        max="2"
        step="0.01"
      />
    </div>
    <p class="notes">{{portraitHeightMultiplierHint}}</p>
  </div>

  <div class="form-group portrait-breathing-multiplier-section">
    <label>{{portraitBreathingMultiplierLabel}}</label>
    <div class="form-fields">
      <input
        type="range"
        name="portraitBreathingMultiplier"
        value="{{portraitBreathingMultiplier}}"
        min="0"
        max="3"
        step="0.05"
      />
      <input
        type="number"
        class="breathing-multiplier-value-display"
        value="{{portraitBreathingMultiplier}}"
        min="0"
        max="3"
        step="0.05"
      />
    </div>
    <p class="notes">{{portraitBreathingMultiplierHint}}</p>
  </div>

  <hr class="section-divider" />

  <!-- Кастомные эмоции -->
  <section class="emotions-section">
    <header class="section-header">
      <h3 class="section-title">{{customEmotionsLabel}}</h3>

      <div class="form-group emotion-show-standard">
        <label class="inline-checkbox">
          <input
            type="checkbox"
            name="showStandardEmotions"
            value="1"
            {{#if showStandardEmotions}}checked{{/if}}
          />
          {{showStandardLabel}}
        </label>
      </div>
    </header>

    <!-- Список эмоций -->
    <div class="emotions-list">
    {{#each emotions as |emotion idx|}}
        {{> "modules/ginzzzu-portraits/templates/portrait-config-emotion-item.hbs"
        emotion=emotion
        idx=idx
        motions=../motions
        colors=../colors
        }}
    {{/each}}
    </div>



    <!-- Кнопка добавления -->
    <button type="button" class="emotion-add-btn">
      <i class="fas fa-plus"></i> {{addEmotionLabel}}
    </button>
  </section>
</form>
