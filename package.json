{
  "name": "ginzzzu-portraits",
  "private": true,
  "version": "2.2.0",
  "type": "module",
  "scripts": {
    "check": "find scripts -name '*.js' -print0 | xargs -0 -n1 node --check",
    "test": "node --test tests/*.test.mjs",
    "deploy:main": "pnpm --dir ../thilke-server run foundry:release -- apply --target portraits-main --no-bump",
    "deploy:lancer": "pnpm --dir ../thilke-server run foundry:release -- apply --target portraits-lancer --no-bump",
    "deploy:troika": "pnpm --dir ../thilke-server run foundry:release -- apply --target portraits-troika --no-bump",
    "foundry:install": "node ../thilke-server/scripts/foundry-container-runner.mjs install --repo ginzzzu-portraits",
    "foundry:review": "node ../thilke-server/scripts/foundry-container-runner.mjs run --repo ginzzzu-portraits --instance review --world litd"
  }
}
